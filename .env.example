# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Load into your shell before running the CLI (or use python-dotenv):
#   export $(grep -v '^#' .env | xargs)
#   # or on Windows PowerShell: Get-Content .env | ForEach-Object { if ($_ -match '^([^#].+)=(.+)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process') } }

# ---------------------------------------------------------------------------
# IPFS (for --upload-to-ipfs in generate-token-metadata)
# Get a free JWT at https://app.pinata.cloud → API Keys → New Key
# ---------------------------------------------------------------------------
#PINATA_JWT=TOKEN_HERE
# ---------------------------------------------------------------------------
# Solana (optional)
# ---------------------------------------------------------------------------
# RPC URL. Default: https://api.devnet.solana.com
# SOLANA_RPC_URL=https://api.devnet.solana.com

# Your deployed program ID. Only set this if you have a program on Devnet
# and want CLI-derived addresses (project/treasury PDAs) to match.
# STARTUP_CLI_PROGRAM_ID=YourProgram111111111111111111111111111

# ---------------------------------------------------------------------------
# Platform keypair (for API: automatic create-mint and buy without user keypairs)
# Set ONE of these so the server can create mints and sign buy transfers.
# Users never send keypairs: create project -> mint is created; buy -> only buyer_pubkey; sell -> Phantom signs.
# ---------------------------------------------------------------------------
# Base64-encoded 64-byte keypair (e.g. from: python -c "import base64,json; f=open('id.json'); d=json.load(f); print(base64.b64encode(bytes(d)).decode())")
# PLATFORM_KEYPAIR_BASE64=...

# Or path to keypair JSON file (e.g. Solana CLI default)
# PLATFORM_KEYPAIR_PATH=~/.config/solana/id.json
